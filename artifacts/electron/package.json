{
  "name": "@workspace/electron",
  "version": "1.0.0",
  "private": true,
  "description": "Phiri WorshipFlow — Electron desktop app wrapper",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.phiri.worshipflow",
    "productName": "Phiri WorshipFlow",
    "copyright": "Copyright © 2025 Phiri WorshipFlow",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build-resources"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../worshipflow/dist/public",
        "to": "app",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico",
      "installerHeaderIcon": "build-resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Phiri WorshipFlow"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "build-resources/icon.icns",
      "category": "public.app-category.music",
      "darkModeSupport": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build-resources/icons",
      "category": "AudioVideo"
    },
    "protocols": [
      {
        "name": "Phiri WorshipFlow",
        "schemes": ["worshipflow"]
      }
    ]
  },
  "dependencies": {
    "electron-serve": "^2.1.1"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  }
}
